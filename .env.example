# ─────────────────────────────────────────────────────────────────────────────
# eval-harness — environment variables
# Copy to .env (gitignored) and fill in secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM gateway (OpenRouter) ─────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=eval-harness
OPENROUTER_REFERER=http://localhost:3000

# Primary model (Gemini Flash latest via OpenRouter)
DEFAULT_MODEL=google/gemini-flash-latest

# Judge model (used by LLM-as-judge scorers; can match DEFAULT_MODEL)
JUDGE_MODEL=google/gemini-flash-latest

# Cross-model portability set (comma-separated; used by drift/portability scorer)
PORTABILITY_MODELS=google/gemini-flash-latest,meta-llama/llama-3.3-70b-instruct,anthropic/claude-sonnet-4-6,qwen/qwen-2.5-72b-instruct

# Per-call generation defaults
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_S=60
LLM_MAX_RETRIES=4
LLM_RETRY_BACKOFF_BASE_S=1.0

# ── MLflow tracing ───────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///./.data/mlflow.db
MLFLOW_EXPERIMENT_NAME=eval-harness
MLFLOW_ARTIFACT_ROOT=./.data/mlflow-artifacts

# ── Application database (SQLite) ────────────────────────────────────────────
DATABASE_URL=sqlite:///./.data/eval_harness.db
DATABASE_ECHO=false
DATABASE_WAL=true

# ── FastAPI backend ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000

# ── Next.js UI ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# ── Retrieval (FAISS + embeddings) ───────────────────────────────────────────
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=cpu
FAISS_INDEX_DIR=./.data/indices

# ── GEPA / DSPy optimizer ────────────────────────────────────────────────────
GEPA_MAX_ITERS=12
GEPA_POPULATION=8
GEPA_REFLECTION_SAMPLE_SIZE=20
GEPA_PARETO_OBJECTIVES=correctness,groundedness,safety,cost,latency

# ── Cost guardrails (USD) ────────────────────────────────────────────────────
COST_BUDGET_PER_EVAL_USD=2.00
COST_BUDGET_PER_OPT_USD=20.00
COST_HARD_STOP_USD=50.00

# ── Eval defaults ────────────────────────────────────────────────────────────
EVAL_PARALLELISM=4
EVAL_TRACE_SAMPLE_RATE=1.0

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false

# ── Demo-mode toggles (set true on stage for safety) ─────────────────────────
DEMO_MODE=false
DEMO_PRELOAD_TRACES=./.data/prebaked/traces.sqlite
DEMO_PRELOAD_GEPA=./.data/prebaked/gepa_runs.json
